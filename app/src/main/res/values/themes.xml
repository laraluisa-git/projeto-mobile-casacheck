<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tema principal do app seguindo Material Design 3.
        Herda de Theme.MaterialComponents.Light.NoActionBar para usar
        Toolbar customizada com AppBarLayout.
    -->
    <style name="Theme.VistoriaApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Cores principais do Material Design -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>
        <item name="colorPrimaryVariant">@color/md_primary_dark</item>
        <item name="colorSecondary">@color/md_accent</item>
        <item name="colorSecondaryVariant">@color/md_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="android:colorBackground">@color/md_background</item>

        <!-- Tipografia padrão -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Status bar na cor primária escura -->
        <item name="android:statusBarColor">@color/md_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/md_background</item>

        <!-- Estilo padrão dos TextInputLayouts -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>

        <!-- Estilo padrão dos botões -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>

        <!-- Estilo padrão dos chips -->
        <item name="chipStyle">@style/Widget.MaterialComponents.Chip.Filter</item>
    </style>

    <!--
        Tema para a SplashScreen (tela de carregamento inicial).
        Usa cor primária como fundo.
    -->
    <style name="Theme.VistoriaApp.Splash" parent="Theme.VistoriaApp">
        <item name="android:windowBackground">@color/md_primary</item>
    </style>

</resources>
